{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-context.local/schema/knowledge.schema.json",
  "title": "AI Context Knowledge Frontmatter",
  "description": "Contrat minimal d'une fiche de connaissance partagee Git/Markdown.",
  "$comment": "Reference formelle du frontmatter knowledge. Les scripts check-knowledge.sh et build-knowledge-index.sh appliquent le profil MVP en Bash+jq sans dependance a un validateur JSON Schema externe.",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "summary",
    "source_project",
    "owner",
    "confidence",
    "freshness",
    "sensitivity",
    "source_refs",
    "usable_by",
    "status"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "source_project": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "freshness": {
      "type": "object",
      "required": ["checked_at"],
      "additionalProperties": true,
      "properties": {
        "checked_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "status": {
          "type": "string",
          "enum": ["verified", "stale", "unknown"]
        }
      }
    },
    "sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "restricted"]
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "usable_by": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "published", "deprecated", "retracted"]
    }
  }
}
