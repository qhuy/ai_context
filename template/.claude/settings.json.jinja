{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .ai/scripts/pre-turn-reminder.sh --format=json",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -qE '^git[[:space:]]+commit' || exit 0; msg=$(jq -r '.tool_input.command' | grep -oE -- '-m[[:space:]]+\"[^\"]*\"' | head -n1 | sed -E 's/^-m[[:space:]]+\"(.*)\"$/\\1/'); CLAUDE_COMMIT_MSG=\"$msg\" bash .ai/scripts/check-commit-features.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
