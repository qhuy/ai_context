#!/bin/bash
# check-features.sh — Valide le maillage de features ({{ project_name }}).
#
# Vérifie pour chaque fichier sous {{ docs_root }}/features/*/*.md :
#   - présence du frontmatter YAML
#   - clés obligatoires : id, scope, title, status
#   - scope == nom du dossier parent
#   - chaque depends_on pointe vers un fichier existant
#
# Usage : bash .ai/scripts/check-features.sh

set -euo pipefail

cd "$(dirname "$0")/../.."

FEATURES_DIR="{{ docs_root }}/features"

fail=0
ok() { printf "  \033[32m✓\033[0m %s\n" "$1"; }
ko() { printf "  \033[31m✗\033[0m %s\n" "$1"; fail=1; }

echo "═══ check-features ═══"

if [[ ! -d "$FEATURES_DIR" ]]; then
  echo "  ⚠️  $FEATURES_DIR absent (aucune feature documentée)"
  exit 0
fi

shopt -s nullglob
files=("$FEATURES_DIR"/*/*.md)

if [[ {% raw %}${#files[@]}{% endraw %} -eq 0 ]]; then
  echo "  ⚠️  aucune feature sous $FEATURES_DIR"
  exit 0
fi

for f in "${files[@]}"; do
  # Extrait le frontmatter (entre --- et ---)
  fm=$(awk '/^---$/{c++;next} c==1' "$f")
  if [[ -z "$fm" ]]; then
    ko "$f : frontmatter manquant"
    continue
  fi

  # Clés obligatoires
  for key in id scope title status; do
    if ! echo "$fm" | grep -qE "^$key:"; then
      ko "$f : clé frontmatter '$key' manquante"
    fi
  done

  # scope == dossier parent
  folder_scope=$(basename "$(dirname "$f")")
  declared_scope=$(echo "$fm" | grep -E '^scope:' | sed -E 's/^scope:[[:space:]]*//; s/["'"'"']//g' | tr -d '[:space:]')
  if [[ -n "$declared_scope" && "$declared_scope" != "$folder_scope" ]]; then
    ko "$f : scope '$declared_scope' ne matche pas le dossier '$folder_scope'"
  fi

  # depends_on : chaque entrée doit pointer vers un fichier existant
  deps=$(awk '/^depends_on:/{flag=1; next} flag && /^  *-/{print; next} flag && /^[^[:space:]]/{flag=0}' "$f" \
    | sed -E 's/^[[:space:]]*-[[:space:]]*//; s/["'"'"']//g')
  while IFS= read -r dep; do
    [[ -z "$dep" ]] && continue
    [[ "$dep" == "[]" ]] && continue
    target="$FEATURES_DIR/$dep.md"
    if [[ ! -f "$target" ]]; then
      ko "$f : depends_on '$dep' → $target introuvable"
    fi
  done <<< "$deps"

  [[ "$fail" -eq 0 ]] && ok "$f"
done

echo
if [[ "$fail" -eq 0 ]]; then
  echo "✅ PASS"
  exit 0
else
  echo "❌ FAIL"
  exit 1
fi
