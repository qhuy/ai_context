{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-context.local/schema/feature.schema.json",
  "title": "AI Context Feature Frontmatter",
  "description": "Contrat minimal des features markdown (frontmatter YAML).",
  "type": "object",
  "required": ["id", "scope", "title", "status", "depends_on", "touches"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "done", "deprecated", "archived"]
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*/[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "touches": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "progress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["spec", "implement", "test", "review", "done", "blocked"]
        },
        "step": {
          "type": "string"
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resume_hint": {
          "type": "string"
        },
        "updated": {
          "type": "string",
          "pattern": "^$|^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        }
      }
    }
  }
}
