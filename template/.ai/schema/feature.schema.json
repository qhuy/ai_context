{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-context.local/schema/feature.schema.json",
  "title": "AI Context Feature Frontmatter",
  "description": "Contrat minimal des features markdown (frontmatter YAML).",
  "$comment": "Rôle dans ai_context : SOURCE de référence du contrat frontmatter. Les enums (status, progress.phase) et le pattern `id` en sont dérivés et appliqués par check-features.sh (read_schema_enum + regex alignée). Ce n'est PAS un validateur JSON-Schema complet exécuté au runtime — l'éthos est bash/jq/yq sans dépendance ajv/check-jsonschema. Les consommateurs downstream peuvent valider leurs fiches contre ce schéma avec leur propre outil.",
  "type": "object",
  "required": ["id", "scope", "title", "status", "depends_on", "touches"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "done", "deprecated", "archived"]
    },
    "type": {
      "$comment": "Optionnel dans le schema vN pour migration progressive ; check-features.sh signale son absence et le rendra requis lors de la prochaine rupture de contrat documentée.",
      "type": "string",
      "enum": ["feature", "contract", "workflow", "reference"]
    },
    "description": {
      "type": "string"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*/[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "touches": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "touches_shared": {
      "description": "Surfaces partagées utiles au reporting/review mais non bloquantes pour la fraîcheur documentaire.",
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "external_refs": {
      "description": "Références vers specs, stories, tickets ou artefacts externes. Permet de relier BMAD, Spec Kit, Linear, Jira, GitHub, etc. sans dupliquer leur contenu.",
      "type": "object",
      "additionalProperties": {
        "type": ["string", "array", "object", "null"]
      }
    },
    "doc": {
      "description": "Niveau documentaire et modules conditionnels requis pour faire de la fiche la source de vérité de la feature.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "level": {
          "type": "string",
          "enum": ["brief", "standard", "full"]
        },
        "requires": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "auth": { "type": "boolean" },
            "data": { "type": "boolean" },
            "ux": { "type": "boolean" },
            "api_contract": { "type": "boolean" },
            "rollout": { "type": "boolean" },
            "observability": { "type": "boolean" }
          }
        }
      }
    },
    "progress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["spec", "implement", "test", "review", "done", "blocked"]
        },
        "step": {
          "type": "string"
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resume_hint": {
          "type": "string"
        },
        "updated": {
          "type": "string",
          "pattern": "^$|^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        }
      }
    },
    "product": {
      "description": "Lien produit optionnel. Pour scope=product, décrit une initiative. Pour les autres scopes, relie la feature à une initiative product/<id>.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["initiative"]
        },
        "initiative": {
          "type": "string",
          "pattern": "^product/[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "contribution": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        },
        "bet": {
          "type": "string"
        },
        "target_user": {
          "type": "string"
        },
        "success_metric": {
          "type": "string"
        },
        "leading_indicator": {
          "type": "string"
        },
        "decision_state": {
          "type": "string",
          "enum": ["explore", "commit", "cut", "pivot", "scale"]
        },
        "next_decision_date": {
          "type": "string",
          "pattern": "^$|^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "kill_criteria": {
          "type": "array",
          "items": { "type": "string" }
        },
        "portfolio": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "appetite": { "type": "string", "enum": ["small", "medium", "large"] },
            "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
            "expected_impact": { "type": "string", "enum": ["low", "medium", "high"] },
            "urgency": { "type": "string", "enum": ["low", "medium", "high"] },
            "strategic_fit": { "type": "string", "enum": ["low", "medium", "high"] }
          }
        }
      }
    }
  }
}
