      flag && /^[^[:space:]]/{flag=0}
    ' "$file" | sed -E 's/^[[:space:]]*//; s/[[:space:]]+$//')
    if [[ -n "$external_refs_raw" ]]; then
      external_refs_json=$(printf '%s\n' "$external_refs_raw" | awk '
        /^[A-Za-z0-9_.-]+:/ {
          key=$0
          sub(/:.*/, "", key)
          val=$0
          sub(/^[^:]+:[[:space:]]*/, "", val)
          gsub(/^"|"$/, "", val)
          if (val != "") print key "\t" val
        }
      ' | jq -Rn '
        reduce inputs as $line ({};
          ($line | split("\t")) as $p
          | if ($p|length) >= 2 then . + {($p[0]): $p[1]} else . end
