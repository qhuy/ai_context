    step=$(echo "$fm" | yq -r '.progress.step // ""')
    blockers_json=$(echo "$fm" | yq -o=json -I=0 '.progress.blockers // []')
    resume_hint=$(echo "$fm" | yq -r '.progress.resume_hint // ""')
    updated=$(echo "$fm" | yq -r '.progress.updated // ""')
  else
