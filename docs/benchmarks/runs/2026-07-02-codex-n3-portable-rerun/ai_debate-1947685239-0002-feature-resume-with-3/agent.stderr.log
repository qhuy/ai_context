    touches_shared_json=$(extract_list_awk "$file" "touches_shared" | jq -R . | jq -s .)
    deps_json=$(extract_list_awk "$file" "depends_on" | jq -R . | jq -s .)
    external_refs_raw=$(awk '
      /^external_refs:/{flag=1; next}
