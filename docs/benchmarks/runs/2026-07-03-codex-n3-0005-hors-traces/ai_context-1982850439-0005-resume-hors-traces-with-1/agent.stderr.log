/bin/zsh -lc "ruby -ryaml -rjson -rdate -e '
Dir[\".docs/features/**/*.md\"].reject { |p| p.end_with?(\".worklog.md\") }.filter_map do |p|
  txt = File.read(p)
  next unless txt.start_with?(\"---\\n\")
  fm = txt.split(/"'^---'"\\s*"'$/, 3)[1]
  next unless fm
  data = YAML.safe_load(fm, permitted_classes: [Date], aliases: true) || {}
  progress = data["progress"] || {}
  step = progress["step"].to_s
  hint = progress["resume_hint"].to_s
  updated = progress["updated"].to_s
  next unless data["status"].to_s == "active" && !step.strip.empty? && !hint.strip.empty? && !updated.strip.empty?
  feature = p.sub(%r{''^'"\\.docs/features/}, \"\").sub(/\\.md"'$/, "")
