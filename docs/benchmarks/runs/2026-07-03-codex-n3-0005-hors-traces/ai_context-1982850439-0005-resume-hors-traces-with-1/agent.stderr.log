  feature = p.sub(%r{''^'"\\.docs/features/}, \"\").sub(/\\.md"'$/, "")
  {"feature"=>feature, "step"=>step, "next"=>hint, "updated"=>updated}
end.compact
h = candidates.sort_by { |x| [-Date.parse(x["updated"]).jd, x["feature"]] }.first
puts JSON.pretty_generate(h.reject { |k,_| k == "updated" })
