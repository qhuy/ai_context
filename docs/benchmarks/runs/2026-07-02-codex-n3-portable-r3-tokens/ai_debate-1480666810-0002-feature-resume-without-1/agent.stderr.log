routing_state: produced | needs_review | needs_response | normative_proposal | challenged_pending_response | consensus_pending_human | consensus | blocked | error
next_agent: claude | codex | human | none
stop_reason: ""        # requis si routing_state est consensus, consensus_pending_human, blocked ou error
iteration: 3
role: producer | reviewer
human_state: none | read | answer | decide | arbitrate | clarify
headline: "Résumé court du tour"
question: "Question précise à trancher, vide si human_state=none"
options:
  - "1) Option A"
  - "2) Option B"

